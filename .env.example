# ─────────────────────────────────────────────────────────────────────
# video-downloader — Backend Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────

# Flask secret key (change this in production!)
SECRET_KEY=change-me-to-a-long-random-string

# Port the Flask dev server listens on (default: 5000)
PORT=5000

# Frontend origin allowed by CORS
# Change to your production URL when deploying
FRONTEND_URL=http://127.0.0.1:5500

# ── Download settings ─────────────────────────────────────────────────

# Default server-side save directory
# Leave empty to use ~/Downloads automatically
DOWNLOAD_DIR=

# Maximum video duration in seconds (default: 7200 = 2 hours)
MAX_VIDEO_SECONDS=7200

# Maximum output file size in MB (default: 500)
MAX_FILE_MB=500

# ── FFmpeg ────────────────────────────────────────────────────────────
# Path to the ffmpeg binary.
# Leave empty if ffmpeg is already on your system PATH.
# Examples:
#   macOS Homebrew:  /opt/homebrew/bin/ffmpeg
#   Linux:           /usr/bin/ffmpeg
#   Render:          /usr/bin/ffmpeg
FFMPEG_PATH=

# ── Logging ───────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default: DEBUG for local dev)
LOG_LEVEL=DEBUG

# ── Temp directory (intermediate yt-dlp output) ───────────────────────
# Default: /tmp/videodl
TMP_DIR=/tmp/videodl
